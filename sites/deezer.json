{
  "name": "Deezer",
  "url": "https://www.deezer.com/en/",
  "loginUrl": "https://account.deezer.com/en-us/login/",
  "selectors": {
    "loggedInIndicator": "h2.chakra-heading",
    "loggedInText": "Library",
    "username": "input[data-testid='email-field']",
    "password": "input[data-testid='password-field']",
    "submit": "button[data-testid='login-button']",
    "cookieAccept": "button[data-testid='gdpr-btn-accept-all']"
  },
  "checkInterval": 30000,
  "navigationTimeout": 30000,
  "loginTimeout": 120000,
  "retryDelay": 5000,
  "maxRetries": 5,
  "userDataDir": "./browser-data/deezer",
  "chromiumArgs": [
    "--kiosk",
    "--start-maximized",
    "--no-first-run",
    "--disable-infobars",
    "--noerrdialogs",
    "--disable-session-crashed-bubble",
    "--disable-features=TranslateUI",
    "--disable-notifications"
  ]
}
